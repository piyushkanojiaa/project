# Backend Environment Variables

# Database Configuration
DATABASE_URL=sqlite:///./orbital_guard.db
# For PostgreSQL: postgresql://user:password@localhost:5432/orbital_guard

# Space-Track.org Credentials (Optional - for live TLE data)
SPACETRACK_USERNAME=your_username_here
SPACETRACK_PASSWORD=your_password_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ML Model Paths
DNN_MODEL_PATH=models/collision_dnn.pth
LSTM_MODEL_PATH=models/trajectory_lstm.pth
RL_MODEL_PATH=models/maneuver_rl.zip

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log
