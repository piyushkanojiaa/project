{
    "name": "orbital-guard-ai",
    "version": "1.0.0",
    "author": "Orbital Guard AI Team",
    "description": "AI-powered space debris collision avoidance system",
    "license": "MIT",
    "main": "electron/main.js",
    "homepage": "./",
    "private": true,
    "type": "module",
    "dependencies": {
        "@deck.gl/core": "^9.2.6",
        "@deck.gl/layers": "^9.2.6",
        "@deck.gl/react": "^9.2.6",
        "@react-three/drei": "^9.96.0",
        "@react-three/fiber": "^8.15.0",
        "clsx": "^2.1.1",
        "deck.gl": "^9.2.6",
        "framer-motion": "^12.26.2",
        "graphql-ws": "^6.0.7",
        "lucide-react": "^0.263.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^7.12.0",
        "recharts": "^3.7.0",
        "satellite.js": "^5.0.0",
        "tailwind-merge": "^3.4.0",
        "three": "^0.160.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/three": "^0.182.0",
        "@vitejs/plugin-react": "^4.0.0",
        "autoprefixer": "^10.4.14",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.4.0",
        "electron-is-dev": "^3.0.1",
        "postcss": "^8.4.27",
        "tailwindcss": "^3.3.0",
        "vite": "^4.4.0",
        "wait-on": "^9.0.3"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
        "electron": "electron .",
        "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:build:win": "npm run build && electron-builder --win",
        "electron:build:mac": "npm run build && electron-builder --mac",
        "electron:build:linux": "npm run build && electron-builder --linux",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    }
}
