# ============================================================
# Environment Variables for Docker Compose
# Copy this to .env and customize
# ============================================================

# Application
ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (PostgreSQL)
POSTGRES_DB=orbital_guard
POSTGRES_USER=admin
POSTGRES_PASSWORD=secure-password-change-this
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis-password-change-this
REDIS_PORT=6379

# Backend API
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,https://yourdomain.com

# Frontend
FRONTEND_PORT=80
VITE_GRAPHQL_HTTP=http://localhost:8000/graphql
VITE_GRAPHQL_WS=ws://localhost:8000/graphql
VITE_API_URL=http://localhost:8000

# Nginx (Production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Monitoring (Optional)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# External APIs (Optional)
SPACETRACK_USERNAME=your-spacetrack-username
SPACETRACK_PASSWORD=your-spacetrack-password

# Deployment
COMPOSE_PROJECT_NAME=orbital-guard
